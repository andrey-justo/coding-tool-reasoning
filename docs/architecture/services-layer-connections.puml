@startuml
title Services Layer Connections
left to right direction

skinparam componentStyle rectangle

actor "MCP Client" as Client

package "Services Layer" {
  component "SWE MCP Server" as MCP
  component "SweMcpToolRegistry" as REG
  component "PlanSweCodeChangeTool" as PLAN
  component "BuildSweCodeContextTool" as CTXB
  component "ApplyPlanSweCodeChangeTool" as APPLY
  component "JudgeSweCodeChangeTool" as JUDGE
  component "FindBestIssueCandidatesTool" as RANK
  component "IssueExperimentRunner" as EXP
  component "RepositoryIssueLocalizer" as LOC
  component "ExperimentReportWriter" as REPORT
}

package "Core Layer" {
  component "SweKnowledgeBase" as KB
  component "CodeGenPlan" as CGP
  component "SweContext" as CTX
  component "SweCodeChangeExplanation" as EXPL
}

component "External LLM" as LLM

Client --> MCP : request workflow
MCP --> REG : dispatch operation

REG --> PLAN : plan_swe_code_change
PLAN --> KB : gather guidance
PLAN --> LLM : planner call
PLAN --> CGP : produce plan

REG --> CTXB : build_swe_code_context
CTXB --> KB : assemble context input
CTXB --> CTX : produce context

REG --> APPLY : apply_plan_swe_code_change
APPLY --> LLM : generate code
REG --> JUDGE : judge_swe_code_change
JUDGE --> LLM : explain/judge
JUDGE --> EXPL : output explanation
REG --> RANK : find_best_issue_candidates_for_current_pr

EXP --> LOC : localize target files
EXP --> MCP : call MCP tools sequence
EXP --> REPORT : persist experiment artifacts

MCP --> Client : structured result

@enduml